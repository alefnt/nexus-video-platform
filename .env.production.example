# 生产环境变量配置模板
# FILE: /video-platform/.env.production.example
# 
# 使用方法:
#   1. 复制此文件: cp .env.production.example .env.production
#   2. 填写所有必需的值
#   3. 确保不要将 .env.production 提交到 Git
#
# 安全提醒:
#   - 所有密钥必须使用强随机值
#   - 推荐使用 Secret Manager (Vault, AWS Secrets Manager)
#   - 定期轮换密钥

# ============== 必需配置 ==============

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql://nexus:CHANGE_ME_STRONG_PASSWORD@db.example.com:5432/nexus_video?connection_limit=50&pool_timeout=30

# JWT 密钥 (必须 32 字符以上)
# 生成方法: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_STRONG_SECRET_AT_LEAST_32_CHARS

# Redis
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis.example.com:6379

# 前端 URL (CORS 白名单)
FRONTEND_URL=https://app.example.com

# ============== 区块链配置 ==============

# CKB 节点
CKB_NODE_URL=https://mainnet.ckb.dev
CKB_INDEXER_URL=https://mainnet.ckb.dev/indexer
CKB_DEPOSIT_ADDRESS=ckb1qyq...your_mainnet_address

# Fiber Network (支付通道)
FIBER_RPC_URL=https://fiber.example.com:8227
FIBER_ALLOW_MOCK=false
FIBER_ENABLE_SIGCHECK=true

# ============== 第三方服务 ==============

# 邮件服务 (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@example.com

# LiveKit (直播)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://livekit.example.com

# Livepeer (转码)
LIVEPEER_API_KEY=your_livepeer_api_key

# Meilisearch (搜索)
MEILISEARCH_URL=https://search.example.com
MEILISEARCH_KEY=your_meilisearch_master_key

# MinIO / S3 (存储)
MINIO_ENDPOINT=https://s3.example.com
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key

# ============== 监控与通知 ==============

# Sentry (错误监控)
SENTRY_DSN=https://xxx@sentry.io/xxx

# ntfy (推送通知)
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=nexus-video-prod

# ============== 可选配置 ==============

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 启用追踪
ENABLE_TRACING=true

# JoyID CKB 支付
ENABLE_POINTS_JOYID=1

# 管理员接口 (谨慎启用)
ENABLE_ADMIN_CKB_INTENTS=0

# ============== 服务端口 (K8s 内部使用) ==============

IDENTITY_PORT=8080
PAYMENT_PORT=8091
CONTENT_PORT=8092
METADATA_PORT=8093
ROYALTY_PORT=8094
NFT_PORT=8095
LIVE_PORT=8096
ACHIEVEMENT_PORT=8097
GOVERNANCE_PORT=8098
BRIDGE_PORT=8099
TRANSCODE_PORT=8100
SEARCH_PORT=8101
MODERATION_PORT=8102
MESSAGING_PORT=8103
ENGAGEMENT_PORT=8104
