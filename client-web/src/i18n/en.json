        "subtitle": "The Digital Campfire of the Future: Decentralized, Gamified, and Owned by You.",
        "executiveSummary": {
            "title": "1. Executive Summary",
            "p1": "Nexus Protocol is a next-generation decentralized video streaming platform built on the <strong class=\"text-white\">CKB (Common Knowledge Base)</strong> blockchain and the <strong class=\"text-white\">RGB++</strong> protocol. It aims to revolutionize the creator economy by returning data ownership and revenue to creators and users through a transparent, high-performance, and gamified ecosystem.",
            "p2": "Unlike traditional platforms (Web2) that monopolize traffic and revenue, Nexus leverages <strong class=\"text-white\">Fiber Network</strong> for instant micropayments and <strong class=\"text-white\">IPFS</strong> for censorship-resistant storage, creating a truly free and open improved \"Web3 YouTube.\""
        },
        "painPoints": {
            "title": "2. Industry Pain Points",
            "creators": {
                "title": "For Creators",
                "items": [
                    "<strong>Revenue Cuts:</strong> Web2 platforms take 45%-55% of ad revenue.",
                    "<strong>Data Lock-in:</strong> Followers and content belong to the platform.",
                    "<strong>Opaque Algorithms:</strong> Traffic distribution is biased."
                ]
            },
            "users": {
                "title": "For Users",
                "items": [
                    "<strong>Attention Exploitation:</strong> Value generated by watching ads yields $0 return.",
                    "<strong>Privacy Violations:</strong> Data harvested and sold.",
                    "<strong>Passive Experience:</strong> Lack of immersive engagement."
                ]
            }
        },
        "solution": {
            "title": "3. The Nexus Solution",
            "intro": "Nexus introduces a triple-layer innovation stack: <strong>Asset Protocol + Payment Network + Gamified Experience</strong>.",
            "content": {
                "title": "3.1 Content as Assets (RGB++)",
                "desc": "Every video is minted as an RGB++ NFT. This ensures true ownership on the Bitcoin/CKB ecosystem and automated royalties for secondary sales."
            },
            "w2e": {
                "title": "3.2 Watch-to-Earn",
                "desc": "Validated watch time generates <strong>$NXP</strong>. Users share 50% of ad revenue and earn rewards for engagement."
            },
            "optimization": {
                "title": "3.3 Lightning Optimization",
                "desc": "Fiber Network enables instant, gas-free micropayments (1 CKB) and Pay-Per-Minute streaming."
            }
        },
        "ecosystem": {
            "title": "4. Ecosystem & Features",
            "live": {
