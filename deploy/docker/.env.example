# 生产环境配置模板
# 复制为 .env 并填写实际值
#
# ⚠️ 安全提醒:
#   - 绝不要将 .env 提交到版本控制
#   - 生产环境建议使用 Vault/KMS 管理密钥
#   - JWT_SECRET 长度至少 32 位

# 数据库
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://nexus:${DB_PASSWORD}@postgres:5432/nexus_video

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# JWT 密钥 (至少 32 位字符)
JWT_SECRET=your_32_char_or_longer_jwt_secret

# CKB 网络
CKB_NODE_URL=https://testnet.ckb.dev/rpc
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer
CKB_DEPOSIT_ADDRESS=your_deposit_address

# LiveKit (直播)
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Livepeer (转码)
LIVEPEER_API_KEY=your_livepeer_key

# MinIO (对象存储)
MINIO_ACCESS_KEY=nexus
MINIO_SECRET_KEY=your_minio_secret

# Meilisearch (搜索)
MEILISEARCH_KEY=your_meilisearch_master_key

# SMTP (邮件)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Grafana (监控)
GRAFANA_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000

# ntfy (通知)
NTFY_TOPIC=nexus-video

# 前端
API_GATEWAY_URL=https://api.yourdomain.com

# TLS 证书目录 (nginx 使用)
SSL_CERT_DIR=./ssl

# Fiber (CKB L2 支付)
FIBER_RPC_URL=

# 日志级别 (trace/debug/info/warn/error/fatal)
LOG_LEVEL=info

# Slack/Discord Webhook (部署通知)
SLACK_WEBHOOK=
