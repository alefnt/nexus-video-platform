# Nexus Video Platform — Production Environment Template
# Copy to .env and fill in real values

# ============== SECURITY ==============
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING_XXXXXXXXXXXXXXXXXXXXXXXX
CSRF_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS

# ============== DATABASE ==============
DATABASE_URL=postgresql://nexus:PASSWORD@db:5432/nexus_video?schema=public

# ============== REDIS ==============
REDIS_URL=redis://:PASSWORD@redis:6379/0

# ============== CKB BLOCKCHAIN ==============
CKB_NODE_URL=https://mainnet.ckb.dev/rpc
CKB_INDEXER_URL=https://mainnet.ckb.dev/indexer
CKB_DEPOSIT_ADDRESS=ckb1qyq...your_cold_wallet_address
ENABLE_POINTS_JOYID=1

# ============== FIBER NETWORK (L2 Payment) ==============
FIBER_RPC_URL=http://fiber-node:8227
FIBER_NODE_PUBKEY=your_fiber_node_public_key
FIBER_ALLOW_MOCK=0

# ============== RGB++ ==============
RGBPP_CKB_PRIVATE_KEY=0x...private_key_for_rgb_splits

# ============== OBJECT STORAGE (MinIO / S3) ==============
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_MEDIA_BUCKET=media
MINIO_PUBLIC_URL=https://media.your-domain.com

# ============== CDN ==============
CDN_ENABLED=true
CDN_GLOBAL_URL=https://cdn.your-domain.com
CDN_CN_URL=https://cdn-cn.your-domain.com
# CDN Providers (choose one):
# Cloudflare R2: CDN_PROVIDER=cloudflare
# 又拍云: CDN_PROVIDER=upyun
# 七牛: CDN_PROVIDER=qiniu
CDN_PROVIDER=cloudflare

# ============== AI SERVICES (BYOK default) ==============
# Platform fallback keys (used when user hasn't configured their own)
OPENAI_API_KEY=sk-...
REPLICATE_API_TOKEN=r8_...
SUNO_API_KEY=...

# ============== MEILISEARCH ==============
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_MASTER_KEY

# ============== SERVICE PORTS ==============
GATEWAY_PORT=8080
CONTENT_PORT=8081
IDENTITY_PORT=8082
PAYMENT_PORT=8083
ROYALTY_PORT=8094
METADATA_PORT=8093
SEARCH_PORT=8095
MODERATION_PORT=8102
AI_GENERATION_PORT=8098
LIVE_PORT=8096
MESSAGING_PORT=8097

# ============== DOMAIN ==============
DOMAIN=your-domain.com
CLIENT_URL=https://your-domain.com
API_URL=https://api.your-domain.com
