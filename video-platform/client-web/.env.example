# 前端环境变量模板（复制为 .env.local 使用）
# 构建时注入，仅 VITE_ 前缀会暴露给客户端

# 网关（必填）
VITE_API_GATEWAY_URL=http://localhost:8080

# JoyID / .bit 登录
# VITE_JOYID_APP_URL=https://testnet.joyid.dev
VITE_JOYID_ICON_URL=/joyid.png
VITE_BIT_ICON_URL=/bit.png
VITE_EMAIL_ICON_URL=/email.png

# 开发/调试
# VITE_DEV_AUTO_LOGIN=0
# VITE_ENABLE_REAL_POINTS_BUY=0

# 监控与统计（可选）
# VITE_SENTRY_DSN=
# VITE_ENABLE_ANALYTICS=0
