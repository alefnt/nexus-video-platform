# 前端 Nginx 镜像
# FILE: /video-platform/deploy/docker/Dockerfile.web
#
# 构建上下文应为项目根目录:
#   docker build -f deploy/docker/Dockerfile.web -t nexus-web .

FROM node:22-alpine AS builder
WORKDIR /app

# 安装 monorepo 根依赖
COPY package*.json ./
COPY shared/package*.json ./shared/
COPY client-web/package*.json ./client-web/

RUN npm ci

# 复制 shared（client-web 依赖 @video-platform/shared）
COPY shared ./shared
# 复制前端源码
COPY client-web ./client-web

WORKDIR /app/client-web
RUN npm run build

# Nginx 运行阶段
FROM nginx:alpine

# 复制构建产物
COPY --from=builder /app/client-web/dist /usr/share/nginx/html

# 复制 Nginx 配置（从构建上下文根目录）
COPY deploy/docker/nginx.conf /etc/nginx/nginx.conf

# 安全: 非 root 运行 (nginx alpine 支持)
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

EXPOSE 80 443
CMD ["nginx", "-g", "daemon off;"]
