# ==================================
# 视频平台环境变量配置模板
# 复制此文件为 .env.local 并填写实际值
# ==================================

# 数据库
DATABASE_URL=postgresql://nexus:password@localhost:5432/nexus_video

# Redis
REDIS_URL=redis://:nexus123@localhost:6379

# CKB 区块链
CKB_NODE_URL=https://testnet.ckb.dev
CKB_INDEXER_URL=https://testnet.ckb.dev/indexer
CKB_DEPOSIT_ADDRESS=ckt1qrfrwcdnvssswdwpn3s9v8fp87emat306ctjwsm3nmlkjg8qyza2cqgqqxxuffhycu3z0gg365a4v07ymp68kwfu3ukg5eau

# 安全（请使用强密钥）
JWT_SECRET=your-32-character-secret-key-here

# 前端
FRONTEND_URL=http://localhost:5173

# 前端 Vite 变量（client-web；构建时注入，见 client-web/.env.example）
VITE_API_GATEWAY_URL=http://localhost:8080
# VITE_JOYID_APP_URL=https://testnet.joyid.dev
# VITE_SENTRY_DSN=
# VITE_ENABLE_ANALYTICS=0

# 邮件服务（请填写您的SMTP信息）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# Fiber Network
FIBER_RPC_URL=http://18.163.221.211:8227
FIBER_RPC_URL_MAINNET=https://fiber-mainnet.ckb.dev/rpc
FIBER_NETWORK=testnet
FIBER_ALLOW_MOCK=false
FIBER_ENABLE_SIGCHECK=false

# 支付服务
PAYMENT_MODE=credits
PLATFORM_FEE_PERCENTAGE=5
CREATOR_ROYALTY_PERCENTAGE=5
PAYMENT_PUBLIC_BASE=http://localhost:8091
ENABLE_POINTS_JOYID=1

# 服务端口
NFT_PORT=8095
LIVE_PORT=8096
ACHIEVEMENT_PORT=8097
GOVERNANCE_PORT=8098
BRIDGE_PORT=8099
TRANSCODE_PORT=8100
SEARCH_PORT=8101
MODERATION_PORT=8102
MESSAGING_PORT=8103
ENGAGEMENT_PORT=8104

# 搜索引擎
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-key

# 通知服务
NTFY_URL=http://localhost:8070
NTFY_TOPIC=nexus-video

# 对象存储 (MinIO)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=nexus
MINIO_SECRET_KEY=your-minio-secret
MINIO_PUBLIC_URL=http://localhost:9000

# CDN 配置 (可选，生产环境推荐)
# 留空 = 直接使用 MinIO 提供文件（开发模式）
# 生产环境选择一个 CDN，配置后 cdn.ts 自动切换
#
# Cloudflare R2 (全球加速，免费 10GB/月出站):
#   CDN_GLOBAL_URL=https://cdn.yourdomain.com
#
# 又拍云 (国内加速，免费 10GB/月):
#   CDN_CN_URL=https://cdn-cn.yourdomain.com
#
# 七牛 Kodo (国内视频加速):
#   CDN_GLOBAL_URL=https://your-bucket.qiniudn.com
#
CDN_GLOBAL_URL=
CDN_CN_URL=

# LiveKit (直播)
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=ws://localhost:7880

# Livepeer (转码)
LIVEPEER_API_KEY=your-livepeer-api-key
